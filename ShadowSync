# ShadowSync

A secure and lightweight file backup and synchronization tool written in Python.

## Features


```python
import os
import shutil
from datetime import datetime

SOURCE_FOLDER = "data"
BACKUP_FOLDER = "backup"

def backup_files():
    if not os.path.exists(BACKUP_FOLDER):
        os.makedirs(BACKUP_FOLDER)

    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    destination = os.path.join(BACKUP_FOLDER, f"backup_{timestamp}")

    shutil.copytree(SOURCE_FOLDER, destination)

    print(f"Backup completed: {destination}")

if __name__ == "__main__":
    backup_files()
```

